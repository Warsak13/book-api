# Server Configuration
PORT=6780 
NODE_ENV=development

# Security & CORS
JWT_SECRET=replace_with_a_64_byte_random_hex_string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:6780

# Payment security
# Stripe keys — get these from your Stripe Dashboard (test mode) or via `stripe listen` for local webhook testing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
FRONTEND_URL=http://localhost:6780

# Database Configuration
DB_HOST=book_api_postgres
DB_USER=postgres 
DB_PASSWORD=your_db_password
DB_NAME=book_database
DB_PORT=5432

# Redis Configuration
REDIS_HOST=book_api_redis
REDIS_PORT=6379

# Email Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password